@model List<Backstage.Models.ACLObject>
@{
    Layout = TempData["Open"].ToString() == "_self" ? null : "~/Views/Shared/_WindowLayout.cshtml";
}

<div>
    <nav>
        <div>
            <img src="~/images/Icon/user_icon.png" class="round" width="96" height="96" />
        </div>
        <h1>名子</h1>
    </nav>

    <section class="wrap">
        @foreach (var item in Model) {
            <div class="function">
                <button data-href="@item.ExecuteURL" data-value="@item.ID" data-click="1">
                    <div>
                        <img src="@item.Icon" width="48" height="48" asp-append-version="true" />
                    </div>
                    <div>
                        <h3>@item.Name</h3>
                        <span>@item.Directions</span>
                    </div>
                </button>
            </div>
        }

    </section>
</div>